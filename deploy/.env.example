# Medical RAG System - Environment Variables Example
# Copy this file to `.env` and modify as needed

# ============================================
# Backend Configuration
# ============================================

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=False

# API
API_PREFIX=/api/v1
SECRET_KEY=your-secret-key-change-in-production

# ============================================
# LLM Configuration
# ============================================

# OpenAI API
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.1
OPENAI_MAX_TOKENS=2000

# Alternative: Azure OpenAI
# AZURE_OPENAI_API_KEY=your-azure-key
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_API_VERSION=2024-02-15-preview

# ============================================
# Database Configuration
# ============================================

# MySQL
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=rag_user
MYSQL_PASSWORD=rag_password
MYSQL_DATABASE=medical_rag
MYSQL_CHARSET=utf8mb4

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================
# Vector Database (Milvus)
# ============================================

MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_COLLECTION=medical_records
MILVUS_DIMENSION=1024

# Embedding Model
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSION=1024

# Reranker Model
RERANKER_MODEL=BAAI/bge-reranker-large

# ============================================
# Search Engine (Elasticsearch)
# ============================================

ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_INDEX=medical_records

# ============================================
# Data Configuration
# ============================================

# Data paths
DATA_DIR=./data
UPLOAD_DIR=./data/uploads
CACHE_DIR=./data/cache

# ============================================
# Logging
# ============================================

LOG_LEVEL=INFO
LOG_DIR=./logs
LOG_FILE=app.log

# ============================================
# Security
# ============================================

# CORS
CORS_ORIGINS=["http://localhost","http://localhost:80","http://localhost:8000"]

# Rate limiting
RATE_LIMIT_PER_MINUTE=60

# ============================================
# Docker Compose Specific
# ============================================

# MySQL root password
MYSQL_ROOT_PASSWORD=root_password

# Compose project name
COMPOSE_PROJECT_NAME=medical-rag
