# 环境变量配置示例文件
# 复制此文件为 .env 并填入实际配置

# 应用配置
DEBUG=True

# OpenAI 配置（必须配置）
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_API_BASE=  # 可选：自定义 API 基础 URL
OPENAI_MODEL=gpt-4o

# Milvus 配置
MILVUS_HOST=localhost
MILVUS_PORT=19530

# Elasticsearch 配置
ES_HOST=localhost
ES_PORT=9200

# MySQL 配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=password
MYSQL_DATABASE=medical_rag

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379

# 日志配置
LOG_LEVEL=INFO
